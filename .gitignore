# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs (if anyone tries one anyway)
.venv/
venv/
env/

# DuckDB extensions (regenerable; project-local cache used by the build)
.duckdb_ext/

# Per-source fetch cache (Overpass / Overture / FSQ raw responses).
# Lets `python -m static.build --force` skip the slow re-fetches when
# only the merge / mapping logic changed.
.fetch_cache/

# City bundles: ship only the gzipped ones. Uncompressed JSON siblings are
# 100+ MB and nothing reads them.
static/site/data/*.json

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
.claude
